<ServerManagerConfiguration>
<ProxyGroup name='sources'>



<SourceProxy class='vtkSteeringDataGenerator' name='SteerableParameters_SCALARS'>
            <IntVectorProperty name='PartitionType' command='SetPartitionType' number_of_elements='1' default_values='1' panel_visibility='never'>
            </IntVectorProperty>

            <IntVectorProperty name='FieldAssociation' command='SetFieldAssociation' number_of_elements='1' default_values='0' panel_visibility='never'>
            </IntVectorProperty>


              <!-- SimParams struct (hardcoded steering fields) -->
              <DoubleVectorProperty name='simp.temperature'
                                    label='Temperature'
                                    command='SetTuple1Double'
                                    clean_command='Clear'
                                    use_index='1'
                                    initial_string='steerable_field_b_simp.temperature'
                                    number_of_elements_per_command='1'
                                    repeat_command='1'
                                    default_values='11'

                                    
              >
                  <!-- <DoubleRangeDomain name='range' min='0.0'  max='5.0'/> -->
                  <Documentation>
                    The temperature of the simulation.
                  </Documentation>
              </DoubleVectorProperty>
              <DoubleVectorProperty name='simp.steps'
                                 label='Steps'
                                 command='SetTuple1Double'
                                 clean_command='Clear'
                                 use_index='1'
                                 initial_string='steerable_field_b_simp.steps'
                                 number_of_elements_per_command='1'
                                 repeat_command='1'
                                 default_values='10'> <Documentation>Number of simulation steps.</Documentation>
              </DoubleVectorProperty>

              <IntVectorProperty name='simp.reset_btn'
                                 label='Reset Simulation'
                                 command='SetTuple1Int'
                                 clean_command='Clear'
                                 use_index='1'
                                 initial_string='steerable_field_b_simp.reset_btn'
                                 number_of_elements_per_command='1'
                                 repeat_command='1'
                                 default_values='0'
                                 >
                  <Documentation>Reset the simulation state.</Documentation>
              </IntVectorProperty>

         
      
      <PropertyGroup label='Simulation Parameters' panel_widget='PropertyCollection'>
          <Hints>
            <PropertyCollectionWidgetPrototype group='misc' name='simpPrototype' />
          </Hints>
          <Property name='simp.temperature' function='simp:temperature'/>
          <Property name='simp.steps'       function='simp:steps'/>
          <Property name='simp.reset_btn'   function='simp:reset'/>
      </PropertyGroup>
  <!-- 
      <PropertyGroup label='Unusable'>
          <StringVectorProperty>
            <Hints>
              <PlaceholderText>Enter label</PlaceholderText>
            </Hints>
          </StringVectorProperty>
          Buttons
          other 
      </PropertyGroup> -->
      <Hints>
      
        <CatalystInitializePropertiesWithMesh mesh='steerable_channel_0D_mesh'>
          <Property name='simp.temperature' association='point' array='steerable_field_f_simp.temperature'/>
          <Property name='simp.steps'       association='point' array='steerable_field_f_simp.steps'/>
          <Property name='simp.reset_btn'   association='point' array='steerable_field_f_simp.reset_btn'/>
        </CatalystInitializePropertiesWithMesh> 
      </Hints>
</SourceProxy>




<SourceProxy class='vtkSteeringDataGenerator' name='SteerableParameters_LinMaps'>
            <IntVectorProperty name='PartitionType' command='SetPartitionType' number_of_elements='1' default_values='1' panel_visibility='never'>
            </IntVectorProperty>

            <IntVectorProperty name='FieldAssociation' command='SetFieldAssociation' number_of_elements='1' default_values='0' panel_visibility='never'>
            </IntVectorProperty>

            <!-- Dynamic list properties for LinMaps (two maps shown as example defaults) -->
            <DoubleVectorProperty name='LinMaps.x_row'
                                  command='SetTuple3Double'
                                  use_index='1'
                                  clean_command='Clear'
                                  initial_string='steerable_field_b_array:LinMaps.x_row'
                                  number_of_elements_per_command='3'
                                  repeat_command='1'
                                  default_values='10 20 30 1 2 3'>
            </DoubleVectorProperty>

            <DoubleVectorProperty name='LinMaps.y_row'
                                  command='SetTuple3Double'
                                  use_index='1'
                                  clean_command='Clear'
                                  initial_string='steerable_field_b_array:LinMaps.y_row'
                                  number_of_elements_per_command='3'
                                  repeat_command='1'
                                  default_values='40 50 60 4 5 6'>
            </DoubleVectorProperty>

            <DoubleVectorProperty name='LinMaps.z_row'
                                  command='SetTuple3Double'
                                  use_index='1'
                                  clean_command='Clear'
                                  initial_string='steerable_field_b_array:LinMaps.z_row'
                                  number_of_elements_per_command='3'
                                  repeat_command='1'
                                  default_values='70 80 90 7 8 9'>
            </DoubleVectorProperty>

            <IntVectorProperty name='LinMaps.time'
                                  command='SetTuple1Int'
                                  clean_command='Clear'
                                  use_index='1'
                                  initial_string='steerable_field_b_array:LinMaps.time'
                                  number_of_elements_per_command='1'
                                  repeat_command='1'
                                  default_values='1.5 2.5'>
            </IntVectorProperty>



         
      <PropertyGroup label='LinMaps' panel_widget='PropertyCollection'>
          <Hints>
            <PropertyCollectionWidgetPrototype group='misc' name='LinMapPrototype' />
          </Hints>
          <Property name='LinMaps.time'  function='LinMaps:time' />
          <Property name='LinMaps.x_row' function='LinMaps:x_row' />
          <Property name='LinMaps.y_row' function='LinMaps:y_row' />
          <Property name='LinMaps.z_row' function='LinMaps:z_row' />
      </PropertyGroup>
      

      <Hints>
        <CatalystInitializePropertiesWithMesh mesh='steerable_channel_1D_mesh_array:LinMaps'>
          <Property name='LinMaps.x_row' association='point' array='steerable_field_f_array:LinMaps.x_row' />
          <Property name='LinMaps.y_row' association='point' array='steerable_field_f_array:LinMaps.y_row' />
          <Property name='LinMaps.z_row' association='point' array='steerable_field_f_array:LinMaps.z_row' />
          <Property name='LinMaps.time'  association='point' array='steerable_field_f_array:LinMaps.time' />
        </CatalystInitializePropertiesWithMesh>
      </Hints>
</SourceProxy>

        
        




  <!-- Array-of-Struct (SimParams vector) steering channel -->
<SourceProxy class='vtkSteeringDataGenerator' name='SteerableParameters_simpVec'>
    <IntVectorProperty name='PartitionType' command='SetPartitionType' number_of_elements='1' default_values='1' panel_visibility='never'/>
    <IntVectorProperty name='FieldAssociation' command='SetFieldAssociation' number_of_elements='1' default_values='0' panel_visibility='never'/>

    <!-- Dynamic list properties for SimParams vector (three initial structs) -->
    <DoubleVectorProperty name='simpVec.temperature'
                          command='SetTuple1Double'
                          use_index='1'
                          clean_command='Clear'
                          initial_string='steerable_field_b_array:simpVec.temperature'
                          number_of_elements_per_command='1'
                          repeat_command='1'
                          default_values='1.0 2.0 3.0'>
      <Documentation>SimParams.temperature across array entries.</Documentation>
    </DoubleVectorProperty>
    <IntVectorProperty name='simpVec.steps'
                       command='SetTuple1Int'
                       use_index='1'
                       clean_command='Clear'
                       initial_string='steerable_field_b_array:simpVec.steps'
                       number_of_elements_per_command='1'
                       repeat_command='1'
                       default_values='0 5 10'>
      <Documentation>SimParams.steps across array entries.</Documentation>
    </IntVectorProperty>
    <IntVectorProperty name='simpVec.reset_btn'
                       command='SetTuple1Int'
                       use_index='1'
                       clean_command='Clear'
                       initial_string='steerable_field_b_array:simpVec.reset_btn'
                       number_of_elements_per_command='1'
                       repeat_command='1'
                       default_values='0 0 0'
                       panel_widget='CheckBox'>
      <!-- <BooleanDomain name='bool'/> -->
      <Documentation>Reset button states per struct entry.</Documentation>
    </IntVectorProperty>

    <PropertyGroup label='SimParams Vector' panel_widget='PropertyCollection'>
      <Hints>
        <PropertyCollectionWidgetPrototype group='misc' name='simpStructPrototype'/>
      </Hints>
      <Property name='simpVec.temperature' function='simpVec:temperature'/>
      <Property name='simpVec.steps'       function='simpVec:steps'/>
      <Property name='simpVec.reset_btn'   function='simpVec:reset_btn'/>
    </PropertyGroup>

    <Hints>
    
      <CatalystInitializePropertiesWithMesh mesh='steerable_channel_1D_mesh_array:simpVec'>
        <Property name='simpVec.temperature'  association='point' array='steerable_field_f_array:simpVec.temperature'/>
        <Property name='simpVec.steps'        association='point' array='steerable_field_f_array:simpVec.steps'/>
        <Property name='simpVec.reset_btn'    association='point' array='steerable_field_f_array:simpVec.reset_btn'/>
      </CatalystInitializePropertiesWithMesh>
    </Hints>
</SourceProxy>

</ProxyGroup>

















<ProxyGroup name='misc'>
    
    <Proxy name='LinMapPrototype' label='LinMaps'>
        <IntVectorProperty name='LinMaps:time' label='Time'
            number_of_elements='1' default_values='0.0'>
            <!-- <DoubleRangeDomain name="range" min="0.0" max="10.0" /> -->
        </IntVectorProperty>


        <DoubleVectorProperty name='LinMaps:x_row' label='X Row'
            number_of_elements='3' default_values='1 0 0' >
          <DoubleRangeDomain name='range' min='-99' max='99'/>
          <Hints>
                <ShowComponentLabels>
                  <ComponentLabel component='0' label='X'/>
                  <ComponentLabel component='1' label='Y'/>
                  <ComponentLabel component='2' label='Z'/>
                </ShowComponentLabels>
                <ShowLabel />

              </Hints>
        </DoubleVectorProperty>

        <DoubleVectorProperty name='LinMaps:y_row' label='Y Row'
            number_of_elements='3' default_values='0 1 0'>
          <DoubleRangeDomain name='range' min='-99' max='99'/>
                        <Hints>
                <ShowComponentLabels>
                  <ComponentLabel component='0' label='X'/>
                  <ComponentLabel component='1' label='Y'/>
                  <ComponentLabel component='2' label='Z'/>
                </ShowComponentLabels>
              </Hints>
        </DoubleVectorProperty>
        <DoubleVectorProperty name='LinMaps:z_row' label='Z Row'
            number_of_elements='3' default_values='0 0 1'>
          <DoubleRangeDomain name='range' min='-99' max='99'/>
                        <Hints>
                <ShowComponentLabels>
                  <ComponentLabel component='0' label='X'/>
                  <ComponentLabel component='1' label='Y'/>
                  <ComponentLabel component='2' label='Z'/>
                </ShowComponentLabels>
              </Hints>
        </DoubleVectorProperty>
    </Proxy>


      
    <Proxy name='simpPrototype' label='simp'> 

      <DoubleVectorProperty name='simp:temperature' label='Temperature'
          number_of_elements='1' default_values='0.0'>
      </DoubleVectorProperty>

      <DoubleVectorProperty name='simp:steps' label='Steps'
          number_of_elements='1' default_values='0.0'>
      </DoubleVectorProperty>

      <IntVectorProperty name='simp:reset_btn' label='Reset'
          number_of_elements='1' default_values='0'>
          <BooleanDomain name='bool'/>
      </IntVectorProperty>

    </Proxy>

    <Proxy name='simpStructPrototype' label='simpVec'>

      <DoubleVectorProperty name='simpVec:temperature' label='temperature'
                            number_of_elements='1' default_values='0.0'/>
      <IntVectorProperty name='simpVec:steps' label='steps'
                         number_of_elements='1' default_values='0'/>
      <IntVectorProperty name='simpVec:reset_btn' label='reset_btn'
                         number_of_elements='1' default_values='0'>
        <BooleanDomain name='bool'/>
      </IntVectorProperty>

    </Proxy>

</ProxyGroup>







</ServerManagerConfiguration>
